# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ReelForge local data
/data
/data.db*
/public/projects/
/out/
/.env.local

# Veo job artefacts (downloaded MP4s, source uploads)
/public/veo/

# Voice sample cache (regenerated on demand)
/public/voice-samples/

# User-supplied music — README stays, MP3s don't
# /public/music/*.mp3   (placeholders are committed; replace freely)

.codegraph/
.claude/
/data/
/public/voice-ab/
/public/voice-ab-demo/
/public/seg-test/
/public/cine-demo/
/public/runs/

# Local TTS microservice — 9GB venv + Python caches stay local (rebuild via uv sync)
/scripts/tts-service/.venv/
**/__pycache__/
*.pyc

# Test render scratch (large mp4s, regenerated on demand)
/public/effects-test/
/public/depth-test/
